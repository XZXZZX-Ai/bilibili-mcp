{
  "name": "@xzxzzx/bilibili-mcp",
  "version": "1.3.8",
  "description": "Bilibili MCP tool for video metadata, transcripts, subtitles, and comment summarization",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bilibili-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:env": "node -e \"console.log('检查环境变量...'); console.log('BILIBILI_SESSDATA:', process.env.BILIBILI_SESSDATA ? '✅ 已配置' : '❌ 未配置'); console.log('BILIBILI_BILI_JCT:', process.env.BILIBILI_BILI_JCT ? '✅ 已配置' : '❌ 未配置'); console.log('BILIBILI_DEDEUSERID:', process.env.BILIBILI_DEDEUSERID ? '✅ 已配置' : '❌ 未配置');\"",
    "release": "semantic-release"
  },
  "config": {
    "bilibili": {
      "rateLimitMs": 500,
      "requestTimeoutMs": 10000,
      "cacheSize": 100
    }
  },
  "files": [
    "dist",
    "README.md",
    "README_EN.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bilibili",
    "video",
    "comments",
    "subtitle",
    "transcript",
    "metadata",
    "chinese",
    "b站",
    "视频总结",
    "评论总结"
  ],
  "author": "xzxzzx",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/365903728-oss/bilibili-mcp.git"
  },
  "homepage": "https://github.com/365903728-oss/bilibili-mcp#readme",
  "bugs": {
    "url": "https://github.com/365903728-oss/bilibili-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "dotenv": "^17.2.4",
    "quick-lru": "^7.3.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@types/node": "^22.19.8",
    "esbuild": "^0.24.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
